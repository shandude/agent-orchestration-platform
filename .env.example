# ── Copy this file to `.env` and fill in your values ────────────────
# Never commit the real .env — it is gitignored.

# REQUIRED: Google Gemini API key (free tier works).
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Default model used by agents unless overridden per-agent.
DEFAULT_MODEL=gemini-2.5-flash

# OPTIONAL: Telegram bot token (create a bot via @BotFather).
# If left blank, the platform runs normally but the Telegram channel
# stays disabled.
TELEGRAM_BOT_TOKEN=

# ── Infrastructure (sensible defaults; rarely need changing) ────────
DATABASE_URL=sqlite:///./data/orchestrator.db
# Comma-separated list of origins allowed to call the API / WS.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Hard cap on graph supersteps to stop runaway feedback loops.
MAX_GRAPH_ITERATIONS=25
